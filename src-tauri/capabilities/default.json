{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "允许核心功能及本地视频播放",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "opener:default",
    "opener:allow-open-path",
    "fs:default",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-mkdir",
    "fs:allow-copy-file",
    "fs:allow-write-file"
  ]
}